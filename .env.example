# ─── Required ────────────────────────────────────────────────────────────────
# Your mail server's FQDN (e.g., mail.yourdomain.com)
HOSTNAME=mail.example.com

# ─── Admin ──────────────────────────────────────────────────────────────────
# Initial admin credentials (used on first start only)
SEED_USER=admin
SEED_PASS=MUST-BE-CHANGED

# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL password — CHANGE THIS in production
DB_PASSWORD=MUST-BE-CHANGED

# ─── Timezone ───────────────────────────────────────────────────────────────
TZ=UTC

# ─── Let's Encrypt (optional) ──────────────────────────────────────────────
# Email for Let's Encrypt certificate notifications
CERTBOT_EMAIL=admin@example.com

# ─── Security ───────────────────────────────────────────────────────────────
# bcrypt cost factor (default: 12, range: 4-31)
# Higher = slower to hash, harder to brute force
BCRYPT_COST=12

# ─── Ports (usually fine as-is) ────────────────────────────────────────────
SMTP_PORT=25
SUBMISSION_PORT=587
SMTPS_PORT=465
SMTP_ALT_PORT=2525
IMAP_PORT=143
IMAPS_PORT=993
POP3_PORT=110
POP3S_PORT=995
HTTP_PORT=8080
